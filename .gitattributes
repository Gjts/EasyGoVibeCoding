/src/frontend/EasyGoVibeCoding/app/**/*.[jt]s text eol=lf
/src/frontend/EasyGoVibeCoding/app/**/*.[jt]sx text eol=lf
/src/frontend/EasyGoVibeCoding/app/**/*.json text eol=lf
/src/frontend/EasyGoVibeCoding/components/**/*.[jt]s text eol=lf
/src/frontend/EasyGoVibeCoding/components/**/*.[jt]sx text eol=lf
/src/frontend/EasyGoVibeCoding/components/**/*.json text eol=lf
/src/frontend/EasyGoVibeCoding/lib/**/*.[jt]s text eol=lf
/src/frontend/EasyGoVibeCoding/lib/**/*.[jt]sx text eol=lf
/src/frontend/EasyGoVibeCoding/lib/**/*.json text eol=lf
/src/frontend/EasyGoVibeCoding/data/**/*.[jt]s text eol=lf
/src/frontend/EasyGoVibeCoding/data/**/*.[jt]sx text eol=lf
