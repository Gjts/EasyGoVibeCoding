/src/frontend/EasyGoVibeCoding/components/ja/** !text !eol
/src/frontend/EasyGoVibeCoding/lib/ja/** !text !eol

# Generated catalogs are hashed byte-for-byte in deterministic extraction checks.
/src/frontend/EasyGoVibeCoding/i18n/catalog/*.json text eol=lf
